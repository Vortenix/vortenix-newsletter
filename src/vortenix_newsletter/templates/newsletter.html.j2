<!doctype html><html><body style="margin:0;background:#f4f5f7;color:#172033;font-family:Arial,sans-serif"><main style="max-width:720px;margin:auto;background:white;padding:32px"><h1 style="color:#273b8f">Vortenix</h1><p>{{ newsletter.edition_date }}</p><h2>{{ newsletter.title }}</h2><p>{{ newsletter.executive_summary }}</p>{% for section in newsletter.sections %}<h2 style="border-top:2px solid #273b8f;padding-top:20px">{{ section.heading }}</h2><p>{{ section.introduction }}</p>{% for item in section.items %}<h3>{{ item.title }}</h3><p><strong>Development:</strong> {{ item.development }}</p><p><strong>Interpretation:</strong> {{ item.significance }}</p><p>Score: {{ item.rank_score }}</p><ul>{% for citation in item.citations %}<li><a href="{{ citation.url }}">{{ citation.source_title }}</a> - {{ citation.supporting_excerpt }}</li>{% endfor %}</ul>{% endfor %}<h3>What to watch</h3><ul>{% for watch in section.what_to_watch %}<li>{{ watch }}</li>{% endfor %}</ul>{% endfor %}<hr><p style="font-size:12px">Finance content is research information only and is not financial advice.</p></main></body></html>
